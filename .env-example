# ========================================数据库配置========================================

# MySQL 数据库配置
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER="your_mysql_user"
DB_PASSWORD="your_mysql_password"
DB_NAME="gitllm"

# SQLAlchemy 连接字符串 (Python 使用)
# 格式: mysql+aiomysql://user:password@host:port/dbname
DATABASE_URL="mysql+aiomysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# PostgreSQL Checkpoint 数据库连接
CHECKPOINT_DATABASE_URL="postgresql+asyncpg://your_pg_user:your_pg_password@localhost:5432/checkpoints"

# ========================================CORS配置========================================
# 允许的前端来源（逗号分隔多个）
CORS_ORIGINS="http://localhost:5173"

# ========================================LLM配置========================================
# Kimi
KIMI_API_KEY="your_kimi_api_key"

#Qwen
QWEN_MODEL_API_KEY="your_qwen_api_key"
QWEN_MODEL_NAME="qwen3-max-2026-01-23"
QWEN_MODEL_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL_PROVIDER="tongyi"
